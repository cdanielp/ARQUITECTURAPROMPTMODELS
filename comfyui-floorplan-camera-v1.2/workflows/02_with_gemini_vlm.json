  "8": {
    "class_type": "GoogleAI_TextVisionNode",
    "inputs": {
      "image": ["1", 0],
      "prompt": "You are an expert architect analyzing a floor plan. The camera is positioned at the highlighted area. Analyze this floor plan and respond with ONLY this format:\n\nROOM_TYPE: [kitchen/bathroom/living_room/bedroom/dining_room/hallway/office]\nVISIBLE_ELEMENTS: [list what is visible: windows, doors, island, countertops, appliances, furniture, etc.]\nMATERIALS_HINTS: [any materials visible in the plan annotations]\nSPACE_CHARACTER: [compact/medium/spacious]\nNOTABLE_FEATURES: [anything special: double height, skylight, open plan, etc.]\n\nBe specific and architectural. Only describe what you can actually see in the plan.",
      "model": "gemini-2.5-flash",
      "api_key": "",
      "system_prompt": "You are a licensed architect with 20 years of experience reading and interpreting architectural floor plans. You identify room types, spatial relationships, structural elements, openings, and furniture layouts from plan drawings. Always respond in the exact format requested. Be precise and factual - only describe what you can see in the plan, never invent elements."
    },
    "_meta": {"title": "8. Gemini VLM \u2014 Analiza Plano \ud83e\udde0"}
  },
  "7": {
    "class_type": "ArchPromptCombinerNode",
